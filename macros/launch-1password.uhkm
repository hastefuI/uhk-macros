// launch-1password.uhkm
// @uhkm-name: Launch 1Password
// @uhkm-description: Opens 1Password on macOS via Spotlight.
// @uhkm-os: macos
// @uhkm-version: 1.0.0
// @uhkm-author: hasteful
// @uhkm-license: MIT

setLedTxt 2500 "1PW"

tapKey LG-space
delayUntil 50
write "1Password"
delayUntil 250
tapKey enter
